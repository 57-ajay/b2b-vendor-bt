# ─────────────────────────────────────────────────────────────────────────────
# Vendor Border-Tax Panel — client env. Copy to `.env.local` and fill in.
# Next 16 removed publicRuntimeConfig: anything the browser needs must be
# NEXT_PUBLIC_* and is inlined at build time.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Web SDK — Firebase console → Project settings → Your apps → SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Cloud Functions region for callables. Default us-central1; India → asia-south1.
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# Use the in-memory mock service instead of Firestore (run the UI with no creds).
# 1 = mock, 0/unset = Firestore. The factory also auto-falls-back to the mock
# when the Firebase config above is missing.
NEXT_PUBLIC_USE_MOCK=0

# Point the SDK at local Firebase emulators (auth:9099, firestore:8080, fns:5001).
NEXT_PUBLIC_FIREBASE_EMULATORS=0

# App Check (reCAPTCHA v3 site key) — recommended to protect the public intake
# page / callables from abuse. Leave blank to disable.
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=
