# functions/.env — non-secret config. Copy to `.env` (read by the Firebase CLI).

# Deploy region. MUST match NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION in the app.
FUNCTIONS_REGION=us-central1

# suvidha agent base URL, e.g. https://agent.yourdomain.com
SUVIDHA_API_URL=

# Fallback per-request service fee (₹) when a vendor has no explicit pricing.
BORDER_TAX_SERVICE_FEE=150

# Enforce App Check on the public submitBorderTaxRequest callable (1 = on).
ENFORCE_APP_CHECK=0

# Secrets are NOT set here — use the Firebase CLI so they're stored encrypted:
#   firebase functions:secrets:set INTERNAL_API_KEY      # X-Internal-Key for the agent
#   firebase functions:secrets:set ADMIN_BOOTSTRAP_SECRET # one-time, to create the first vendor
